Panels:
  - Class: rviz_common/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Ground Truth Path1
        - /KF Path1
        - /PoseWithCovariance1
        - /PoseArray1
        - /Map1
        - /Map1/Update Topic1
      Splitter Ratio: 0.5
    Tree Height: 319
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
